# AJOS (jobot) Environment Configuration Template
# Copy your API keys here

# Gemini API Key (Primary Cloud LLM Provider)
GEMINI_API_KEY=

# Optional Fallback Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local Ollama Endpoint (Optional)
OLLAMA_BASE_URL=http://localhost:11434

# System Paths
JOBOT_HOME=~/.jobot
